{
  "name": "@tenkit/release-tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "draft:build": "tsx scripts/build-draft-release-set.ts",
    "plan": "tsx scripts/plan-release.ts",
    "smoke": "pnpm -F @tenkit/template-generator build && tsx scripts/smoke-candidate.ts",
    "verify": "tsx scripts/verify-release.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "@tenkit/template-generator": "workspace:*",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  }
}
