{
  "name": "@tenkit/template-generator",
  "version": "0.1.0",
  "description": "Template generation package for Tenkit Expo projects.",
  "license": "MIT",
  "homepage": "https://github.com/brilliantinsane/tenkit#readme",
  "bugs": {
    "url": "https://github.com/brilliantinsane/tenkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brilliantinsane/tenkit.git",
    "directory": "packages/template-generator"
  },
  "keywords": [
    "app-variants",
    "expo",
    "expo-template",
    "multi-tenant",
    "react-native",
    "runtime-tenants",
    "tenkit",
    "template-generator",
    "typescript",
    "white-label"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./generator": "./dist/generator.mjs",
    "./writer": "./dist/writer.mjs",
    "./local-proof": "./dist/local-proof.mjs"
  },
  "files": [
    "dist",
    "templates",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/generator.ts src/writer.ts src/local-proof.ts --format esm --dts",
    "pack:dry-run": "pnpm pack --dry-run",
    "prepack": "pnpm run build",
    "test": "vitest run tests/generator.test.ts tests/writer.test.ts",
    "test:proof": "vitest run tests/local-proof.test.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "proof": "tsx scripts/generate-proof.ts",
    "verify": "tsx scripts/verify-generated-app.ts"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "fs-extra": "^11.3.5",
    "handlebars": "^4.7.9",
    "is-binary-path": "^3.0.0",
    "pathe": "^2.0.3",
    "tinyglobby": "^0.2.17"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
