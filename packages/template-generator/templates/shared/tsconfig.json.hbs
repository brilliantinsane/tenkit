{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": [
      "node",
      "react"{{#if isUniwindStyling}},
      "uniwind/types"{{/if}}
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"{{#if isUniwindStyling}},
    "src/uniwind-env.d.ts"{{/if}},
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
