import { ThemedView } from '@/components/themed-view';
import { globalStyles } from '@/constants/globals';
import { useActiveRuntimeTenant } from '@/hooks/use-active-runtime-tenant';
import { useTheme } from '@/theme/ThemeContext';
import { FieldGroup, Host, Picker, Row, Spacer, Text } from '@expo/ui';
import { SafeAreaView } from 'react-native-safe-area-context';

export default function SettingsScreen() {
  const { colors, dark } = useTheme();
  const colorScheme = dark ? 'dark' : 'light';
  const {
    activeRuntimeTenantId,
    hasRuntimeTenantSelection,
    selectableRuntimeTenants,
    setActiveRuntimeTenantId,
  } = useActiveRuntimeTenant();

  return (
    <ThemedView style={globalStyles.container}>
      <SafeAreaView style={globalStyles.container}>
        <Host style={globalStyles.container} colorScheme={colorScheme}>
          <FieldGroup style=\{{ backgroundColor: colors.background }}>
            {hasRuntimeTenantSelection ? (
              <Row alignment="center">
                <Text>Active Runtime Tenant</Text>

                <Spacer flexible />

                <Picker selectedValue={activeRuntimeTenantId} onValueChange={setActiveRuntimeTenantId}>
                  {selectableRuntimeTenants.map((runtimeTenant) => (
                    <Picker.Item
                      key={runtimeTenant.runtimeTenantId}
                      label={runtimeTenant.name}
                      value={runtimeTenant.runtimeTenantId}
                    />
                  ))}
                </Picker>
              </Row>
            ) : null}
          </FieldGroup>
        </Host>
      </SafeAreaView>
    </ThemedView>
  );
}
