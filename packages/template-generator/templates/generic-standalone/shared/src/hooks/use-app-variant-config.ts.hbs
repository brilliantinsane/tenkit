import Constants from 'expo-constants';

import { type AppVariantConfigExtra } from '@/types/app-variant';

export function getAppVariantConfig() {
  const extra = Constants.expoConfig?.extra as AppVariantConfigExtra | undefined;

  if (!extra) {
    throw new Error('Expo config is missing App Variant bootstrap data.');
  }

  return {
    appVariant: extra.appVariant,
    theme: extra.theme,
    runtimeTenantAccess: extra.runtimeTenantAccess,
    standaloneRuntimeTenantId: extra.standaloneRuntimeTenantId,
  };
}

export function useAppVariantConfig() {
  return getAppVariantConfig();
}
