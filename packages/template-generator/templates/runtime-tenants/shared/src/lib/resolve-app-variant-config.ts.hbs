import { existsSync } from 'node:fs';
import { join } from 'node:path';

import { appVariant } from '@/constants/app-variant';
import { runtimeTenants } from '@/constants/runtime-tenants';
import { validateRuntimeTenantAccess } from '@/lib/runtime-tenant-access';
import { type ResolvedAppVariantConfig } from '@/types/app-variant';

type ResolveAppVariantInput = {
  slug?: unknown;
  projectRoot?: string;
};

function fail(message: string): never {
  throw new Error(message);
}

function getRequiredAppVariantAssetPaths(slug: string): string[] {
  const assetPath = `assets/${slug}`;
  const icons = `${assetPath}/icons`;
  const iosIcon = `${assetPath}/app.icon`;

  return [
    `${icons}/icon.png`,
    `${icons}/android-icon-foreground.png`,
    `${icons}/android-icon-background.png`,
    `${icons}/android-icon-monochrome.png`,
    `${icons}/splash-icon-light.png`,
    `${icons}/splash-icon-dark.png`,
    `${icons}/favicon.png`,
    `${iosIcon}/icon.json`,
  ];
}

function validateAppVariantAssets(slug: string, projectRoot: string) {
  for (const assetPath of getRequiredAppVariantAssetPaths(slug)) {
    if (!existsSync(join(projectRoot, assetPath))) {
      fail(`Missing required App Variant asset "${assetPath}" for Slug "${slug}"`);
    }
  }
}

export function resolveAppVariantConfig({
  slug,
  projectRoot = process.cwd(),
}: ResolveAppVariantInput = {}): ResolvedAppVariantConfig {
  const selectedSlug = slug === undefined ? appVariant.slug : slug;

  if (typeof selectedSlug !== 'string') {
    fail(`Invalid Slug ${JSON.stringify(selectedSlug)}. Expected: ${appVariant.slug}`);
  }

  if (selectedSlug !== appVariant.slug) {
    fail(`Invalid Slug ${JSON.stringify(selectedSlug)}. Expected: ${appVariant.slug}`);
  }

  validateAppVariantAssets(appVariant.slug, projectRoot);
  validateRuntimeTenantAccess({ appVariant, runtimeTenants });

  const { appVariantId, eas, runtimeTenantAccess, slug: resolvedSlug, theme } = appVariant;
  const extra: ResolvedAppVariantConfig['extra'] = {
    eas: {
      projectId: eas.projectId,
    },
    appVariant: {
      id: appVariantId,
      slug: resolvedSlug,
    },
    theme,
    runtimeTenantAccess,
  };

  return {
    ...appVariant,
    extra,
  };
}
