import '../global.css';

import { DarkTheme, DefaultTheme, ThemeProvider } from 'expo-router/react-navigation';
import { StatusBar } from 'expo-status-bar';
import { useEffect } from 'react';
import { useColorScheme } from 'react-native';
import { Uniwind } from 'uniwind';

import AppTabs from '@/components/app-tabs';
import { useAppVariantConfig } from '@/hooks/use-app-variant-config';

export default function RootLayout() {
  const { theme } = useAppVariantConfig();
  const colorScheme = useColorScheme();
  const dark = colorScheme === 'dark';

  useEffect(() => {
    Uniwind.updateCSSVariables('light', { '--color-accent': theme.accent });
    Uniwind.updateCSSVariables('dark', { '--color-accent': theme.accent });
  }, [theme.accent]);

  const navigationTheme = {
    ...(dark ? DarkTheme : DefaultTheme),
    colors: {
      ...(dark ? DarkTheme : DefaultTheme).colors,
      primary: theme.accent,
    },
  };

  return (
    <>
      <ThemeProvider value={navigationTheme}>
        <AppTabs accent={theme.accent} />
      </ThemeProvider>
      <StatusBar style={dark ? 'light' : 'dark'} />
    </>
  );
}
