{
  "name": "create-tenkit",
  "version": "0.1.1",
  "description": "Thin package-manager create entrypoint for Tenkit.",
  "license": "MIT",
  "homepage": "https://github.com/brilliantinsane/tenkit#readme",
  "bugs": {
    "url": "https://github.com/brilliantinsane/tenkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brilliantinsane/tenkit.git",
    "directory": "packages/create-tenkit"
  },
  "keywords": [
    "app-variants",
    "cli",
    "create",
    "expo",
    "expo-template",
    "multi-tenant",
    "react-native",
    "runtime-tenants",
    "tenkit",
    "white-label"
  ],
  "type": "module",
  "bin": {
    "create-tenkit": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm -F @tenkit/cli build && tsdown src/index.ts --format esm --dts",
    "pack:dry-run": "pnpm pack --dry-run",
    "prepack": "pnpm run build",
    "smoke": "pnpm run build && vitest run tests/smoke.test.ts",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@tenkit/cli": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "fs-extra": "^11.3.5",
    "pathe": "^2.0.3",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
