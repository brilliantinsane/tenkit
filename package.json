{
  "name": "tenkit-workspace",
  "version": "1.0.0",
  "packageManager": "pnpm@11.9.0",
  "private": true,
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  },
  "scripts": {
    "start": "pnpm -F playground start",
    "tenkit": "pnpm -F playground tenkit",
    "android": "pnpm -F playground android",
    "ios": "pnpm -F playground ios",
    "web": "pnpm -F playground web",
    "test": "pnpm -F playground test",
    "template-generator:test": "pnpm -F @tenkit/template-generator test",
    "template-generator:typecheck": "pnpm -F @tenkit/template-generator typecheck",
    "generate:proof": "pnpm -F @tenkit/template-generator generate:proof",
    "generate:white-label-proof": "pnpm -F @tenkit/template-generator generate:white-label-proof",
    "generate:single-app-runtime-tenants-proof": "pnpm -F @tenkit/template-generator generate:single-app-runtime-tenants-proof",
    "generate:generic-with-standalone-app-variants-proof": "pnpm -F @tenkit/template-generator generate:generic-with-standalone-app-variants-proof",
    "verify:generated-app": "pnpm -F @tenkit/template-generator verify:generated-app",
    "verify:generated-generic-with-standalone-app-variants": "pnpm -F @tenkit/template-generator verify:generated-generic-with-standalone-app-variants",
    "verify:generated-single-app-runtime-tenants": "pnpm -F @tenkit/template-generator verify:generated-single-app-runtime-tenants",
    "verify:generated-white-label": "pnpm -F @tenkit/template-generator verify:generated-white-label",
    "typecheck": "pnpm -F playground typecheck",
    "lint": "pnpm -F playground lint",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
