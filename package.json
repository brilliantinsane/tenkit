{
  "name": "tenkit-workspace",
  "version": "1.0.0",
  "packageManager": "pnpm@11.9.0",
  "private": true,
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  },
  "scripts": {
    "start": "pnpm -F playground start",
    "tenkit": "pnpm -F playground tenkit",
    "android": "pnpm -F playground android",
    "ios": "pnpm -F playground ios",
    "web": "pnpm -F playground web",
    "test": "pnpm -F playground test",
    "typecheck": "pnpm -F playground typecheck",
    "lint": "pnpm -F playground lint",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
